# ═══ DATABASE ═══
POSTGRES_DB=animacare
POSTGRES_USER=animacare
POSTGRES_PASSWORD=your_secure_password_here

# ═══ JWT ═══
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_chars

# ═══ REDIS ═══
REDIS_PASSWORD=your_redis_password

# ═══ APP ═══
NODE_ENV=production
CORS_ORIGIN=https://admin.animacare.global

# ═══ SMTP (Email notifications) ═══
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@animacare.global
SMTP_PASS=your_app_password

# ═══ STORAGE (uploads) ═══
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ═══ RATE LIMITING ═══
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
